generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  studentId     String?
  unit          String?
  role          Role      @default(USER)
  applications  Application[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Campaign {
  id          String   @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  templateUrl String?
  formConfig  Json?    // Stores the required fields for the application form
  applications Application[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Application {
  id              String            @id @default(cuid())
  userId          String
  campaignId      String
  status          ApplicationStatus @default(PENDING)
  data            Json              // Store application form data (achievements, etc.)
  evidenceFiles   Json?             // Array of file URLs/IDs
  portraitImage   String?           // The user's portrait image
  certificateUrl  String?           // Generated certificate URL
  adminFeedback   String?
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign        Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
